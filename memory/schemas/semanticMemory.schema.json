{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "semanticMemory.schema.json",
  "title": "SemanticMemoryRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "memory_type",
    "scope",
    "title",
    "content",
    "tags",
    "source",
    "confidence",
    "created_at",
    "updated_at",
    "last_accessed_at",
    "expires_at",
    "owner",
    "visibility",
    "write_reason",
    "retrieval_hints",
    "version",
    "status"
  ],
  "properties": {
    "id": { "type": "string" },
    "memory_type": {
      "type": "string",
      "enum": ["user_preference", "project_fact", "org_fact", "workflow_pattern", "relationship", "identity_fact"]
    },
    "scope": {
      "type": "string",
      "enum": ["global", "workspace", "repo", "thread", "agent"]
    },
    "title": { "type": "string" },
    "content": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "reference", "assertion_mode"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["conversation", "file", "repo", "manual", "system"]
        },
        "reference": { "type": "string" },
        "assertion_mode": {
          "type": "string",
          "enum": ["user_stated", "system_inferred", "repo_confirmed", "agent_assumed"]
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "last_accessed_at": { "type": "string", "format": "date-time" },
    "expires_at": {
      "anyOf": [
        { "type": "null" },
        { "type": "string", "format": "date-time" }
      ]
    },
    "owner": {
      "type": "string",
      "enum": ["user", "system", "agent"]
    },
    "visibility": {
      "type": "string",
      "enum": ["private", "workspace", "repo"]
    },
    "write_reason": { "type": "string" },
    "retrieval_hints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "version": { "type": "integer", "minimum": 1 },
    "status": {
      "type": "string",
      "enum": ["active", "superseded", "deleted"]
    }
  }
}
