{
  "name": "taid-ai",
  "version": "1.0.0",
  "description": "Career AI frontend and documentation foundation for the Agent Identity Platform.",
  "private": true,
  "workspaces": [
    "services/api-gateway",
    "services/pdf-extractor",
    "packages/pdf-signature-verifier",
    "packages/a2a-protocol",
    "packages/badge-schemas",
    "packages/chain-client",
    "packages/did-resolver",
    "packages/sync-adapter-sdk",
    "packages/vc-toolkit"
  ],
  "scripts": {
    "braintrust:bootstrap": "node ./scripts/bootstrap-braintrust.mjs",
    "db:migrate": "tsx packages/persistence/src/migrations.ts",
    "dev": "next dev",
    "dev:apply-worker": "tsx watch scripts/run-autonomous-apply-worker.ts",
    "e2e:recruiter-marketplace": "node ./scripts/e2e/recruiter-marketplace-e2e.mjs",
    "build": "next build",
    "build:railway": "PLAYWRIGHT_BROWSERS_PATH=0 npx playwright install chromium && npm run build",
    "start": "next start",
    "start:railway": "PLAYWRIGHT_BROWSERS_PATH=0 npm run start",
    "test": "vitest run",
    "worker:apply": "tsx scripts/run-autonomous-apply-worker.ts",
    "dev:gateway": "npm --workspace services/api-gateway run dev",
    "dev:extractor": "npm --workspace services/pdf-extractor run dev",
    "build:gateway": "npm --workspace services/api-gateway run build",
    "build:extractor": "npm --workspace services/pdf-extractor run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StefanoCaruso456/Carrer-AI.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/StefanoCaruso456/Carrer-AI/issues"
  },
  "homepage": "https://github.com/StefanoCaruso456/Carrer-AI#readme",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@langchain/core": "^1.1.39",
    "@langchain/langgraph": "^1.2.8",
    "@langchain/openai": "^1.4.4",
    "@types/sanitize-html": "^2.16.1",
    "braintrust": "^3.8.0",
    "cheerio": "^1.2.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "next-auth": "^4.24.13",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "pg-mem": "^3.0.14",
    "playwright": "^1.59.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanitize-html": "^2.17.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "jsdom": "^26.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.1"
  }
}
