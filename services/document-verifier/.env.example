# Document Verifier service configuration

PORT=8787
NODE_ENV=development

# Upstream pdf-extractor service
PDF_EXTRACTOR_URL=http://localhost:8788

# Content extraction: heuristic (demo) | claude (future)
CONTENT_EXTRACTOR=heuristic

# When CONTENT_EXTRACTOR=claude, supply:
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
