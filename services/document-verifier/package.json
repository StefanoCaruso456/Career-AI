{
  "name": "document-verifier",
  "version": "0.1.0",
  "private": true,
  "description": "HTTP service that ingests PDF offer letters and returns a structured verification verdict: tampering signals, authenticity signals, and content match against a claimed employer/role/dates.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "generate:fixture": "tsx scripts/generate-fixture.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "pdf-lib": "^1.17.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "unpdf": "^0.12.0"
  },
  "engines": {
    "node": ">=20"
  }
}
