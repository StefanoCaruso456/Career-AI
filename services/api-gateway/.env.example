# api-gateway configuration

PORT=8080
NODE_ENV=development

# Shared secret Career-AI sends in the Authorization header for the demo.
# Replace with real session auth when identity-service is wired up.
GATEWAY_SHARED_SECRET=dev-career-ai-secret-change-me

# Postgres connection
DATABASE_URL=postgres://career_ledger:career_ledger_dev@localhost:5433/career_ledger

# Upstream PDF extraction service (kept separate for trust-boundary reasons —
# parses untrusted PDF binaries)
PDF_EXTRACTOR_URL=http://localhost:8788

# Content extraction mode for the in-process verifier: heuristic (demo) | claude
CONTENT_EXTRACTOR=heuristic

# Required only when CONTENT_EXTRACTOR=claude
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
